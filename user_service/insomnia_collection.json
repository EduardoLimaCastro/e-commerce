{
  "_type": "export",
  "__export_format": 4,
  "__export_date": "2026-04-21",
  "__export_source": "insomnia.desktop.app",
  "resources": [
    {
      "_id": "wrk_user_service",
      "_type": "workspace",
      "name": "User Service",
      "description": "REST API collection for the User Service",
      "scope": "collection"
    },
    {
      "_id": "env_base",
      "_type": "environment",
      "parentId": "wrk_user_service",
      "name": "Base Environment",
      "data": {
        "base_url": "http://localhost:8081"
      }
    },
    {
      "_id": "fld_users",
      "_type": "request_group",
      "parentId": "wrk_user_service",
      "name": "Users"
    },
    {
      "_id": "req_create_user",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Create User",
      "method": "POST",
      "url": "{{ _.base_url }}/api/users",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
      }
    },
    {
      "_id": "req_list_users",
      "_type": "request",
      "parentId": "fld_users",
      "name": "List Users",
      "method": "GET",
      "url": "{{ _.base_url }}/api/users",
      "headers": [],
      "body": {}
    },
    {
      "_id": "req_get_user_by_id",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Get User by ID",
      "method": "GET",
      "url": "{{ _.base_url }}/api/users/{{ user_id }}",
      "headers": [],
      "body": {}
    },
    {
      "_id": "req_update_user",
      "_type": "request",
      "parentId": "fld_users",
      "name": "Update User",
      "method": "PUT",
      "url": "{{ _.base_url }}/api/users/{{ user_id }}",
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\"\n}"
      }
    }
  ]
}
